# Clerk Authentication Keys
# Retrieve from: Settings -> API Keys in your Clerk Dashboard
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Neon Serverless Postgres Database URL
# Retrieve from your Neon Project Dashboard
DATABASE_URL=postgresql://user:password@ep-host-name.region.pooler.neon.tech/neondb?sslmode=require

# Uploadthing File Storage Token
# Retrieve from: API Keys in your UploadThing Dashboard
UPLOADTHING_TOKEN=your_uploadthing_secret_token

# Polar Payments Credentials
# Retrieve from Settings -> Developers in your Polar Dashboard
POLAR_ACCESS_TOKEN=polar_at_your_access_token
POLAR_WEBHOOK_SECRET=whsec_your_webhook_secret

# Polar Product ID (required to run real checkouts instead of the simulator)
# Retrieve from your Polar Dashboard: Products -> Catalogue -> Copy Product ID
POLAR_PRODUCT_ID=your_polar_product_id

# Public URL of your application (used for checkout redirects & webhook signatures)
NEXT_PUBLIC_APP_URL=http://localhost:3000
